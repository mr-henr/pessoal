# Config do Firebase, em UMA linha de JSON.
# Copie este arquivo para .env.local (que o git ignora) e cole a sua config.
#
# Onde achar: console.firebase.google.com -> seu projeto -> engrenagem (Configurações do projeto)
# -> aba "Geral" -> role até "Seus apps" -> app da Web -> "Configuração do SDK".
#
# Em produção, o mesmo valor vai como secret VITE_FIREBASE_CONFIG no GitHub
# (Settings -> Secrets and variables -> Actions -> New repository secret).

VITE_FIREBASE_CONFIG={"apiKey":"...","authDomain":"SEU-PROJETO.firebaseapp.com","projectId":"SEU-PROJETO","storageBucket":"SEU-PROJETO.firebasestorage.app","messagingSenderId":"...","appId":"..."}
